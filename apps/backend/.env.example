NODE_ENV=development
# Fast Rental API (:4000). Union Rental uses :4001 — do not change.
PORT=4000
PUBLIC_API_BASE_URL=http://localhost:4000
# Fast Rental agent UI (:5173). Union Rental uses :5174 for VITE_PUBLIC_SITE_URL only.
FRONTEND_ORIGIN=http://localhost:5173

SUPABASE_URL=https://twkqsaupojldddclgpqj.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=fast-rental-media
R2_SIGNED_UPLOAD_EXPIRES_SECONDS=900
R2_SIGNED_DOWNLOAD_EXPIRES_SECONDS=300
# auto = local disk in dev if R2 keys are invalid; use r2 in production with R2 S3-compatible keys
STORAGE_DRIVER=auto

GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEET_FAST_RENTAL_ID=1FbQ7VTOE0muIUSfIh3fdBq7Hdle9MgxhmAUrB_Dy4jk
GOOGLE_SHEET_ORCHA_ID=1hnNYOxxiObjBfaNRRlUH6j8AolUaBbmaaRLzt6d2UdA
GOOGLE_SHEET_ORCHA_GID=1483806723

RESEND_API_KEY=
EMAIL_ENABLED=false
EMAIL_FROM="LogiGo <notifications@your-domain.com>"
EMAIL_REPLY_TO=

GEOCODING_PROVIDER=nominatim
GEOCODING_USER_AGENT=FastRental/1.0 admin@example.com
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org/search

# Keep this false in development so hot reloads do not launch a full sync.
RUN_SHEET_SYNC_ON_STARTUP=false
CRON_SHEET_SYNC=0 */6 * * *
CRON_STALE_MEDIA_CLEANUP=30 3 * * *

RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=30
